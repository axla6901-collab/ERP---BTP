# ────────────────────────────────────────────────────────────
# erp-btp — variables d'environnement (template)
# Copier vers .env.local et remplir les valeurs.
# .env.local ne doit JAMAIS être commité (cf. .gitignore).
# ────────────────────────────────────────────────────────────

# ── Base de données PostgreSQL ──
# DATABASE_URL : compte runtime (DML seulement — SELECT/INSERT/UPDATE/DELETE)
# DATABASE_MIGRATOR_URL : compte migrations (DDL — CREATE/ALTER/DROP)
# Cf. db/migrations/0001_db_roles.sql et docs/runbooks/database-accounts.md
DATABASE_URL=postgresql://app_rw:app_rw_dev_password@localhost:5432/erpbtp
DATABASE_MIGRATOR_URL=postgresql://app_migrator:app_migrator_dev_password@localhost:5432/erpbtp

# ── Better Auth ──
# Générer un secret aléatoire :
#   PowerShell : [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
#   Bash       : openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Stockage objet (MinIO en dev, S3-compatible en prod) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=erpbtp_minio
S3_SECRET_ACCESS_KEY=erpbtp_minio_dev_password
S3_BUCKET_DOCUMENTS=erp-btp-documents
S3_FORCE_PATH_STYLE=true

# ── SMTP (Mailpit en dev, SMTP réel en prod) ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@erp-btp.local

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── Sécurité (M2) ──
ENCRYPTION_KEY=

# ── Observabilité (GlitchTip / Sentry-compatible, M1.2 sous-phase F) ──
# DSN vide = pas d'envoi (mode dev sans GlitchTip démarré)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
